node_modules/
dist/
build/
coverage/
.env
.env.local
.DS_Store
*.log

# Obsidian transient state (kept out so collaborators don't fight over pane layouts).
# Everything else under fofafu_vault/ (logs, standups, kanban, features) IS tracked — that's the point.
fofafu_vault/.obsidian/workspace.json
fofafu_vault/.obsidian/workspace-mobile.json
fofafu_vault/.obsidian/workspaces.json
fofafu_vault/.obsidian/graph.json

# VS Code Local History extension
.history/

# Session-summary scratchpad regenerated each Claude Code session.
STATUS.md

# Claude Code per-project state: session transcripts (~/.claude/projects/...
# symlinked here so the memory/ subdir is project-local). Transcripts contain
# raw tool I/O and must NEVER be committed — they can leak secrets.
.claude-state/

# Obsidian auto-creates this when "New canvas" is clicked accidentally.
fofafu_vault/Untitled.canvas

# Supabase CLI local cache (project ref, pooler URL, version pins) — regenerated by `supabase link`.
supabase/.temp/
