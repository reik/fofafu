# Server
PORT=4000
NODE_ENV=development

# Database (Postgres connection string, e.g. from Supabase project settings > Database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Test-only Postgres connection string (disposable Postgres/schema, NOT the prod Supabase DB).
# Required whenever NODE_ENV=test; there is no in-memory/sqlite fallback anymore.
TEST_DATABASE_URL=postgresql://postgres:test@localhost:15432/fofafu_test

# Auth
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP with app password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
FRONTEND_URL=http://localhost:5173
